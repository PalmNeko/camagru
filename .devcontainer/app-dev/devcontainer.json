{
    "name": "App-dev",
    "dockerComposeFile": [
        "./docker-compose.yml"
    ],
    "service": "app-dev",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "moby": false
        },
        "ghcr.io/devcontainers/features/php:1": {}
    },
    "mounts": [
        {
            "source": "${localWorkspaceFolder}",
            "target": "${containerWorkspaceFolder}",
            "type": "bind"
        },
        {
            "source": "for-exclude-vendor",
            "target": "${localWorkspaceFolder}/runtime/services/app/html/vendor",
            "type": "volume"
        }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "usernamehw.errorlens",
                "streetsidesoftware.code-spell-checker",
                "shashraf.vscode-pestphp",
                "renandelmonico.vscode-php-test-explorer",
                "devsense.profiler-php-vscode",
                "devsense.composer-php-vscode",
                "xdebug.php-debug",
                // // exclude extensions ref:https://github.com/microsoft/vscode-docs/blob/main/remote-release-notes/v1_85.md#opt-out-of-extensions
                "-devsense.phptools-vscode",
                "-zobo.php-intellisense",
                "-xdebug.php-pack"
            ]
        }
    },
    "remoteUser": "root",
    "remoteEnv": {
        "LOCAL_WORKSPACE_FOLDER": "${containerWorkspaceFolder}",
        "RUNTIME_TARGET": "dev-container"
    },
    "onCreateCommand": {
        "install-dependencies": [
            "bash",
            "${containerWorkspaceFolder}/.devcontainer/app-dev/install-dependencies.sh"
        ]
    },
    "postStartCommand": {
        "setup-git": "git config --global --add safe.directory ${containerWorkspaceFolder}"
    }
}
